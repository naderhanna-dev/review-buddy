    "install-service": "tsx src/cli.ts install-service",
    "uninstall-service": "tsx src/cli.ts uninstall-service"
  },
  "dependencies": {
    "@reviewradar/shared": "workspace:*",
    "@reviewradar/agents": "workspace:*",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "~5.9.3"
  }
}
